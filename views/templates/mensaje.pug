extends ../layout/index
    
block contenido
    .py-10
        h1.text-4xl.my-10.font-extrabold.text-center.text-indigo-400 Bienes
            span.font-normal.text-black Raíces 
        h2.text-center.text-2xl.font-normal.text-black= pagina

    .mt-8.mx-auto.max-w-xl.pb-5
        .bg-white.py-8.px-4.shadow-2xl.rounded-2xl
            //- Mensaje principal
            p.text-xl.font-bold.text-center.my-10.bg-indigo-100.text-indigo-700.border-l-4.border-indgo-500.p-4.uppercase= mensaje

            //- Lógica para mostrar el botón dinámico
            if buttonVisibility
                div.flex.justify-center.mt-5
                    a(class="w-3/4 bg-indigo-400 text-white hover:bg-indigo-600 font-bold py-3 cursor-pointer shadow-lg hover:shadow-xl uppercase rounded-2xl transition-all duration-300 text-center block"
                            href=buttonURL)= buttonText