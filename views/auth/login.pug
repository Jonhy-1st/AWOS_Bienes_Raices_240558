extends ../layout/index
    
block contenido
    .py-10
        h1.text-4xl.my-10.font-extrabold.text-center.text-indigo-400 Bienes
            span.font-normal.text-black Raíces 
        h2.text-center.text-2xl.font-normal.text-black= pagina

        //- Alertas de Errores
        if errores 
            .max-w-md.mx-auto.my-10 
                each error in errores 
                    p.bg-red-600.text-white.uppercase.text-xs.text-center.p-2.mb-1.font-bold.rounded-md.shadow-sm= error.msg

    .mt-8.mx-auto.max-w-xl.pb-5
        .bg-white.py-8.px-4.shadow-2xl.rounded-3xl
            //- Formulario de Login Manual
            form.space-y-5(method="POST" action="/auth/login" noValidate)    
                input(type="hidden" name="_csrf" value=csrfToken)
                
                div.px-5
                    label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="emailUsuario") Correo electrónico:
                    //- Clases movidas a class="" para evitar error de Pug
                    input#emailUsuario(class="w-full border border-gray-300 px-3 py-2 rounded-xl placeholder-gray-400 focus:ring-2 focus:ring-purple-600 focus:outline-none" placeholder="p.e.: usuario@dominio.com" name="emailUsuario" type="email")

                div.px-5
                    label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="passwordUsuario") Contraseña:
                    input#passwordUsuario(class="w-full border border-gray-300 px-3 py-2 rounded-xl placeholder-gray-400 focus:ring-2 focus:ring-purple-600 focus:outline-none" placeholder="Por lo menos 8 caracteres" name="passwordUsuario" type="password")

                    div.flex.items-center.gap-2.mt-2
                        input#verP1(type="checkbox" class="cursor-pointer h-4 w-4 text-purple-600 rounded" onclick="document.getElementById('passwordUsuario').type = this.checked ? 'text' : 'password'")
                        label.text-xs.text-gray-500.cursor-pointer(for="verP1") Mostrar contraseña    
                
                div.px-5
                    input(class="w-full bg-purple-600 text-white hover:bg-purple-700 font-bold py-3 cursor-pointer shadow-lg hover:shadow-xl uppercase rounded-2xl transition-all duration-300 transform hover:-translate-y-0.5" type="submit" value="Iniciar Sesión")
            
            //- SECCIÓN DE REDES SOCIALES (Discord + GitHub)
            .mt-8.px-5
                .relative
                    .absolute.inset-0.flex.items-center
                        .w-full.border-t.border-gray-200
                    .relative.flex.justify-center.text-xs.uppercase
                        span.bg-white.px-2.text-gray-400 O continúa con

                .grid.grid-cols-2.gap-3.mt-6
                    a(href="/auth/discord" class="w-full inline-flex justify-center items-center py-2.5 px-4 border border-gray-300 rounded-xl shadow-sm bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-all hover:border-indigo-400")
                        img(src="https://www.svgrepo.com/show/353655/discord-icon.svg" class="h-5 w-5 mr-2" alt="Discord")
                        span Discord
                    
                    a(href="/auth/github" class="w-full inline-flex justify-center items-center py-2.5 px-4 border border-gray-300 rounded-xl shadow-sm bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-all hover:border-black")
                        img(src="https://www.svgrepo.com/show/512317/github-142.svg" class="h-5 w-5 mr-2" alt="GitHub")
                        span GitHub

            div.flex.items-center.justify-between.pt-6.px-5
                a(class="text-sm text-gray-500 hover:underline hover:text-purple-600" href="/auth/registro") ¿No tienes cuenta? Regístrate
                a(class="text-sm text-gray-500 hover:underline hover:text-purple-600" href="/auth/recuperarPassword") Olvidé mi contraseña

    footer.text-gray-500.py-6.mt-10
        .max-w-7xl.mx-auto.text-center.text-sm
            p © 2026 Jonhy Neri Hernández - 240558