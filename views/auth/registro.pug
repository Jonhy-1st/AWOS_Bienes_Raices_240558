extends ../layout/index

block contenido
    .py-10
        h1.text-4xl.my-10.font-extrabold.text-center.text-purple-600 Bienes
            span.font-normal.text-black Raíces 
        h2.text-center.text-2xl.font-normal.text-black= pagina

        if errores
            div.max-w-md.mx-auto.my-10
                each error in errores
                    p.bg-red-600.text-white.uppercase.text-xs.text-center.p-2.mb-1.font-bold= error.msg

    .mt-8.mx-auto.max-w-xl.pb-5
        .bg-white.py-8.px-4.shadow-2xl.rounded-2xl
            form.space-y-5(method="POST" action="/auth/registro" noValidate) 
                input(type="hidden" name="_csrf" value=csrfToken)

                div.px-5
                    label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="nombreUsuario") Nombre Completo:
                    input#nombreUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400(placeholder="P.e: Jonhy Neri Hernandez" name="nombreUsuario" value= usuario ? usuario.nombreUsuario: '' type="text")
                
                div.px-5
                    label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="emailUsuario") Correo Electrónico:
                    input#emailUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400(placeholder="P.e: correo@dominio.com" name="emailUsuario" value= usuario ? usuario.emailUsuario: '' type="email")  

                div.px-5
                    label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="passwordUsuario") Contraseña:
                    input#passwordUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400(placeholder="Por lo menos 8 caracteres" name="passwordUsuario" type="password")

                    div.flex.items-center.gap-2.mt-1
                        input#verP1(type="checkbox" class="cursor-pointer" onclick="document.getElementById('passwordUsuario').type = this.checked ? 'text' : 'password'")
                        label.text-xs.text-gray-500.cursor-pointer(for="verP1") Mostrar contraseña

                div.px-5
                    label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="confirmacionUsuario") Confirmar contraseña:
                    input#confirmacionUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400(placeholder="Repite la contraseña anterior" name="confirmacionUsuario" type="password")

                    div.flex.items-center.gap-2.mt-1
                        input#verP2(type="checkbox" class="cursor-pointer" onclick="document.getElementById('confirmacionUsuario').type = this.checked ? 'text' : 'password'")
                        label.text-xs.text-gray-500.cursor-pointer(for="verP2") Mostrar contraseña

                input(class="w-full bg-purple-600 hover:bg-purple-400 hover:transition text-white font-bold py-3 cursor-pointer shadow-lg rounded-4xl uppercase" type="submit" value="Registrar Usuario")

            //- --- NUEVA SECCIÓN: REGISTRO CON REDES SOCIALES ---
            .mt-8.px-5
                .relative.mb-6
                    .absolute.inset-0.flex.items-center
                        .w-full.border-t.border-gray-300
                    .relative.flex.justify-center.text-xs.uppercase
                        span.bg-white.px-2.text-gray-400 O regístrate con

                .grid.grid-cols-2.gap-3
                    a(href="/auth/discord" class="w-full inline-flex justify-center items-center py-2.5 px-4 border border-gray-300 rounded-xl shadow-sm bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-all hover:border-indigo-400")
                        img(src="https://www.svgrepo.com/show/353655/discord-icon.svg" class="h-5 w-5 mr-2" alt="Discord")
                        span Discord
                    
                    a(href="/auth/github" class="w-full inline-flex justify-center items-center py-2.5 px-4 border border-gray-300 rounded-xl shadow-sm bg-white text-sm font-medium text-gray-700 hover:bg-gray-50 transition-all hover:border-black")
                        img(src="https://www.svgrepo.com/show/512317/github-142.svg" class="h-5 w-5 mr-2" alt="GitHub")
                        span GitHub

            div.flex.items-center.justify-between.pt-6.px-5
                a(class="text-gray-500 text-sm hover:decoration-purple-600 hover:underline transition decoration-2" href="/auth/login") ¿Ya tienes cuenta? Inicia Sesión
                a(class="text-gray-500 text-sm hover:decoration-purple-600 hover:underline transition decoration-2" href="/auth/recuperarPassword") ¿Olvidaste tu contraseña? Recuperar

    footer.text-gray-500.py-6.mt-10
        .max-w-7xl.mx-auto.text-center.text-sm
            p © 2026 Jonhy Neri Hernández - 240558