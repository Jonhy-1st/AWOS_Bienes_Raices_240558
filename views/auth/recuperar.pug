extends ../layout/index

block contenido
    div.py-12
        h1.text-4xl.my-10.font-extrabold.text-center.text-purple-600 Bienes
            span.font-normal.text-black  Raíces 
        
        h2.text-center.text-2xl.font-normal.text-black
            | Recuperar contraseña

        p.text-center.text-sm.text-gray-500.mt-2
            | Te enviaremos un email con la liga de restauración de contraseña

        if errores
            div.max-w-md.mx-auto.my-10
                each error in errores
                    p.bg-red-600.text-white.uppercase.text-xs.text-center.p-2.mb-1.font-bold= error.msg

    .mt-8.mx-auto.max-w-xl
        .bg-white.py-8.px-4.shadow-2xl.rounded-2xl
            //- CORRECCIÓN: Action ajustado a recuperarPassword para coincidir con el controlador
            form.space-y-5(method="POST" action="/auth/recuperarPassword" noValidate)

                input(type="hidden" name="_csrf" value=csrfToken)
                
                div.px-5
                    label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="emailUsuario") Correo Electrónico:
                    //- Agregado el value persistente por si hay errores de validación
                    input#emailUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-xl.placeholder-gray-400(
                        placeholder="p.e.: usuario@dominio.com"
                        name="emailUsuario"
                        type="email"
                        value= usuario ? usuario.emailUsuario : ''
                    )

                input(
                    class="w-full bg-purple-600 text-white hover:bg-purple-700 font-bold py-3 cursor-pointer shadow-lg hover:shadow-xl uppercase rounded-2xl transition-all duration-300"
                    type="submit"
                    value="Enviar Correo de Restauración"
                )

                div.flex.items-center.justify-between.pt-3.px-5
                    a(class="text-gray-500 text-sm hover:decoration-purple-600 hover:underline transition decoration-2" href="/auth/login") ¿Ya tienes cuenta? Inicia Sesión
                    a(class="text-gray-500 text-sm hover:decoration-purple-600 hover:underline transition decoration-2" href="/auth/registro") ¿No tienes cuenta? Regístrate

    //- Agregada tu firma y matrícula
    footer.text-gray-500.py-6.mt-10
        .max-w-7xl.mx-auto.text-center.text-sm
            p © 2026 Jonhy Neri Hernández - 240558