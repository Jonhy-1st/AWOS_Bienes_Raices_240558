extends ../layout/index

block contenido
    .py-10
        h1.text-4xl.my-10.font-extrabold.text-center.text-purple-600 Bienes
            span.font-normal.text-black Raíces 
        h2.text-center.text-2xl.font-normal.text-black= pagina

        if errores
            div.max-w-md.mx-auto.my-10
                each error in errores
                    p.bg-red-600.text-white.uppercase.text-xs.text-center.p-2.mb-1.font-bold= error.msg

    .mt-8.mx-auto.max-w-xl.pb-5
        .bg-white.py-8.px-4.shadow-2xl.rounded-2xl
            //- SIN 'action' para mantener el token de la URL
            form.space-y-5(method="POST" noValidate) 
                input(type="hidden" name="_csrf" value=csrfToken)
                
                div.px-5
                    label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="passwordUsuario") Nueva Contraseña:
                    input#passwordUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-xl(placeholder="Mínimo 8 caracteres" name="passwordUsuario" type="password")

                div.px-5
                    label.block.text-sm.uppercase.text-gray-500.mb-2.font-bold(for="confirmacionUsuario") Confirmar Nueva Contraseña:
                    input#confirmacionUsuario.w-full.border.border-gray-300.px-3.py-2.rounded-xl(placeholder="Repite tu contraseña" name="confirmacionUsuario" type="password")

                input(class="w-full bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 cursor-pointer uppercase rounded-2xl" type="submit" value="Guardar Contraseña")

    footer.text-gray-500.py-6.mt-10
        .max-w-7xl.mx-auto.text-center.text-sm
            p © 2026 Jonhy Neri Hernández - 240558